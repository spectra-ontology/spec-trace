@prefix sh:    <http://www.w3.org/ns/shacl#> .
@prefix tdoc:  <https://w3id.org/spectra#> .
@prefix xsd:   <http://www.w3.org/2001/XMLSchema#> .
@prefix dc:    <http://purl.org/dc/elements/1.1/> .

# =============================================================================
# SPECTRA core SHACL shapes — minimal cardinality and type constraints
# These complement the OWL FunctionalProperty / range axioms for instance
# validation in tools that consume SHACL (e.g., TopBraid, pySHACL).
# =============================================================================

tdoc:TdocShape a sh:NodeShape ;
    sh:targetClass tdoc:Tdoc ;
    sh:property [
        sh:path tdoc:tdocNumber ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
    ] ;
    # tdoc:presentedAt is unbounded above: 3GPP TDocs (especially LSs) can be
    # re-tabled across consecutive meetings under the same identifier
    # (~207/123,678 RAN-wide instances in the released snapshot exhibit this
    # pattern). The schema therefore admits multiple presentedAt edges per Tdoc.
    sh:property [
        sh:path tdoc:presentedAt ;
        sh:class tdoc:Meeting ;
    ] ;
    sh:property [
        sh:path tdoc:targetRelease ;
        sh:class tdoc:Release ;
        sh:maxCount 1 ;
    ] .

tdoc:CRShape a sh:NodeShape ;
    sh:targetClass tdoc:CR ;
    # tdoc:modifies is intentionally unbounded: a single CR may amend more than
    # one Spec (e.g., paired updates to a stage-2 and a stage-3 spec).
    sh:property [
        sh:path tdoc:modifies ;
        sh:class tdoc:Spec ;
    ] ;
    sh:property [
        sh:path tdoc:belongsToCRPack ;
        sh:class tdoc:CRPack ;
        sh:maxCount 1 ;
    ] .

tdoc:LSShape a sh:NodeShape ;
    sh:targetClass tdoc:LS ;
    # tdoc:originatedFrom and tdoc:sentTo are intentionally unbounded.
    # A Liaison Statement is frequently issued by, or addressed to, multiple
    # Working Groups simultaneously (cross-WG coordination is the common case).
    # No minCount: outgoing LSs in 3GPP convention have an implicit source
    # (the host WG) and may omit the explicit originatedFrom edge; a small
    # fraction (~5.8% in the released cross-WG snapshot) of LSs in the source
    # KG also lack an explicit sentTo target due to upstream metadata gaps.
    sh:property [
        sh:path tdoc:originatedFrom ;
        sh:class tdoc:WorkingGroup ;
    ] ;
    sh:property [
        sh:path tdoc:sentTo ;
        sh:class tdoc:WorkingGroup ;
    ] .

tdoc:ResolutionShape a sh:NodeShape ;
    sh:targetClass tdoc:Resolution ;
    # tdoc:madeAt has minCount 1 (every Resolution is anchored to at least one
    # Meeting), but no maxCount: a small fraction of Resolutions are recorded
    # at two Meetings under exceptional circumstances (e.g., RAN1 COVID-era
    # double-meeting cases; ~1.0% in the released RAN1 KG).
    sh:property [
        sh:path tdoc:madeAt ;
        sh:class tdoc:Meeting ;
        sh:minCount 1 ;
    ] ;
    sh:property [
        sh:path tdoc:resolutionBelongsTo ;
        sh:class tdoc:AgendaItem ;
        sh:maxCount 1 ;
    ] .

tdoc:SectionShape a sh:NodeShape ;
    sh:targetClass tdoc:Section ;
    sh:property [
        sh:path tdoc:belongsToSpec ;
        sh:class tdoc:Spec ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
    ] ;
    sh:property [
        sh:path tdoc:parentSection ;
        sh:class tdoc:Section ;
        sh:maxCount 1 ;
    ] ;
    # Irreflexive: a section cannot be its own parent.
    # Enforced at the OWL level via owl:IrreflexiveProperty on tdoc:parentSection
    # (see ontology/spectra.ttl). SHACL Core has no portable irreflexivity primitive;
    # if needed, add a sh:sparql shape SELECT $this WHERE { $this tdoc:parentSection $this }.
    .

tdoc:TRImpactShape a sh:NodeShape ;
    sh:targetClass tdoc:TRImpact ;
    sh:property [
        sh:path tdoc:impactsSpec ;
        sh:class tdoc:Spec ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
    ] ;
    sh:property [
        sh:path tdoc:impactOfTR ;
        sh:class tdoc:TechnicalReport ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
    ] ;
    # impactType is a closed enumeration recorded on TR cover pages
    sh:property [
        sh:path tdoc:impactType ;
        sh:in ( "NewTS" "NewSection" "ExtendSection" "NoChange" ) ;
    ] .

tdoc:CRPackShape a sh:NodeShape ;
    sh:targetClass tdoc:CRPack ;
    sh:property [
        sh:path tdoc:hasCR ;
        sh:class tdoc:CR ;
        sh:minCount 1 ;
    ] .

tdoc:WorkingAssumptionShape a sh:NodeShape ;
    sh:targetClass tdoc:WorkingAssumption ;
    sh:property [
        sh:path tdoc:promotedTo ;
        sh:class tdoc:Agreement ;
        sh:maxCount 1 ;
    ] .
