# SPARQL translation of CQ3-1 — Phase 3
# "Change Requests that modify a specific TS section"

PREFIX tdoc: <https://w3id.org/spectra#>

SELECT ?crNumber ?reasonForChange
WHERE {
  ?spec a tdoc:Spec ;
        tdoc:specNumber "38.214" .
  ?sec a tdoc:Section ;
       tdoc:sectionNumber ?sectionNumber ;
       tdoc:belongsToSpec ?spec .
  ?cr a tdoc:CR ;
      tdoc:modifiesSection ?sec ;
      tdoc:tdocNumber ?crNumber ;
      tdoc:reasonForChange ?reasonForChange .
  FILTER (?sectionNumber = "5.1.3")
}
