# SPARQL translation of CQ4-1 — Phase 4
# "Reason for change, summary, and affected section for a given CR"

PREFIX tdoc: <https://w3id.org/spectra#>
PREFIX dc:   <http://purl.org/dc/elements/1.1/>

SELECT ?title ?reasonForChange ?summaryOfChange ?consequencesIfNotApproved ?sectionNumber
WHERE {
  ?cr a tdoc:CR ;
      tdoc:tdocNumber "R1-2500594" ;
      dc:title ?title ;
      tdoc:reasonForChange ?reasonForChange ;
      tdoc:summaryOfChange ?summaryOfChange ;
      tdoc:consequencesIfNotApproved ?consequencesIfNotApproved ;
      tdoc:modifiesSection ?sec .
  ?sec tdoc:sectionNumber ?sectionNumber .
}
