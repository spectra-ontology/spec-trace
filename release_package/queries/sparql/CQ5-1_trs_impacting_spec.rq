# SPARQL translation of CQ5-1 — Phase 5
# "Technical Reports that have impacted a given Technical Specification"

PREFIX tdoc: <https://w3id.org/spectra#>
PREFIX dc:   <http://purl.org/dc/elements/1.1/>

SELECT ?trNumber ?trTitle
WHERE {
  ?spec a tdoc:Spec ;
        tdoc:specNumber "38.211" .
  ?impact a tdoc:TRImpact ;
          tdoc:impactsSpec ?spec ;
          tdoc:impactOfTR ?tr .
  ?tr a tdoc:TechnicalReport ;
      tdoc:trNumber ?trNumber ;
      dc:title ?trTitle .
}
