# Q2 — Cross-WG impact via LS
# "Which LSes did RAN1 send to RAN2 from this meeting?"

PREFIX tdoc: <https://w3id.org/spectra#>
PREFIX dc:   <http://purl.org/dc/elements/1.1/>

SELECT ?lsTdoc ?title ?fromWG ?toWG ?meetingNumber
WHERE {
  ?ls  a tdoc:LS ;
       tdoc:tdocNumber ?lsTdoc ;
       dc:title ?title ;
       tdoc:originatedFrom ?from ;
       tdoc:sentTo ?to ;
       tdoc:presentedAt ?meeting .
  ?from tdoc:wgName ?fromWG .
  ?to   tdoc:wgName ?toWG .
  ?meeting tdoc:meetingNumber ?meetingNumber .
}
